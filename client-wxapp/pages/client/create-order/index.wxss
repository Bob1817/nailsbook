.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 160rpx;
}

.section {
  background: #fff;
  margin-bottom: 16rpx;
  padding: 32rpx 32rpx 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

/* 美甲师 */
.tech-card {
  display: flex;
  align-items: center;
}
.tech-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #f0f0f0;
  margin-right: 24rpx;
}
.tech-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  display: block;
}
.tech-phone {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

/* 服务方式 */
.type-tabs {
  display: flex;
  gap: 24rpx;
}
.type-tab {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #666;
}
.type-tab.active {
  border-color: #ff6b9d;
  color: #ff6b9d;
  background: #fff0f5;
}

/* 地址 */
.address-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
  margin-bottom: 16rpx;
}
.address-item.selected {
  border-color: #ff6b9d;
  background: #fff8fb;
}
.address-main { flex: 1; }
.address-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
}
.address-detail {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}
.check-icon {
  color: #ff6b9d;
  font-size: 36rpx;
  font-weight: bold;
}
.add-address {
  text-align: center;
  color: #ff6b9d;
  font-size: 28rpx;
  padding: 16rpx 0;
}

/* 时间 */
.time-row {
  display: flex;
  gap: 24rpx;
}
.time-item { flex: 1; }
.time-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}
.picker-value {
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  display: flex;
  align-items: center;
}

/* 服务项目 */
.service-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.service-item {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  border: 2rpx solid #ddd;
  font-size: 28rpx;
  color: #666;
}
.service-item.selected {
  border-color: #ff6b9d;
  color: #ff6b9d;
  background: #fff0f5;
}

/* 备注 */
.remark-input {
  width: 100%;
  min-height: 160rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 提交按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
}
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: #ff6b9d;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-submit[disabled] {
  background: #ccc;
}

.hint {
  font-size: 28rpx;
  color: #999;
}
