.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.search-bar {
  background-color: #ffffff;
  padding: 24rpx 32rpx;
}

.search-input {
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.filter-tabs {
  background-color: #ffffff;
  padding: 0 32rpx 24rpx;
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab {
  font-size: 28rpx;
  color: #666666;
  margin-right: 48rpx;
  padding-bottom: 16rpx;
  position: relative;
}

.tab.active {
  color: #ff6b9d;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background-color: #ff6b9d;
  border-radius: 3rpx;
}

.works-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
}

.work-card {
  width: calc(50% - 12rpx);
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  position: relative;
}

.work-card:nth-child(odd) {
  margin-right: 24rpx;
}

.work-cover {
  width: 100%;
  height: 320rpx;
}

.work-info {
  padding: 20rpx;
}

.work-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.work-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tech-info {
  display: flex;
  align-items: center;
}

.tech-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.tech-name {
  font-size: 22rpx;
  color: #999999;
}

.work-stats {
  display: flex;
  align-items: center;
}

.stat {
  font-size: 22rpx;
  color: #999999;
}

.icon {
  color: #ff6b9d;
}

.featured-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background-color: #ff6b9d;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999999;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}
