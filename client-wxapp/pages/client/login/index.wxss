.container {
  min-height: 100vh;
  background-color: #fff;
  padding: 100rpx 48rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-circle {
  width: 120rpx;
  height: 120rpx;
  background: #ff6b9d;
  border-radius: 60rpx;
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.readonly {
  height: 96rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #999;
  display: flex;
  align-items: center;
}

.hint-banner {
  background: #fff7e6;
  color: #fa8c16;
  font-size: 26rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background-color: #ff6b9d;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
}
.btn-primary[disabled] {
  background-color: #ccc;
}

.link {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #ff6b9d;
  margin-top: 32rpx;
}
