.container {
  min-height: 100vh;
  background-color: #ffffff;
  padding: 80rpx 48rpx;
}

.header {
  margin-bottom: 80rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999999;
  display: block;
}

.form {
  margin-bottom: 60rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}

.input {
  height: 96rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
}

.code-input {
  display: flex;
  align-items: center;
}

.code-input .input {
  flex: 1;
  margin-right: 24rpx;
}

.btn-code {
  width: 240rpx;
  height: 96rpx;
  background-color: #fff0f5;
  color: #ff6b9d;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  border: none;
}

.btn-code.disabled {
  color: #cccccc;
  background-color: #f5f5f5;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background-color: #ff6b9d;
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.btn-primary[disabled] {
  background-color: #cccccc;
}

.tips {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 40rpx;
}

.tips-text {
  display: inline;
}

.link {
  display: inline;
  color: #ff6b9d;
}
