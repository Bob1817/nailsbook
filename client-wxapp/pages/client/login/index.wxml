<view class="container">
  <view class="header">
    <text class="title">欢迎来到 NailBook</text>
    <text class="subtitle">登录后享受美甲预约服务</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">手机号</text>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-item">
      <text class="label">验证码</text>
      <view class="code-input">
        <input
          class="input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <button
          class="btn-code"
          bindtap="sendCode"
        >
          {{countText}}
        </button>
      </view>
    </view>

    <button class="btn-primary" bindtap="handleSubmit">
      登录
    </button>
  </view>

  <view class="tips">
    <text class="tips-text">登录即表示同意</text>
    <text class="link">《用户协议》</text>
    <text class="tips-text">和</text>
    <text class="link">《隐私政策》</text>
  </view>
</view>