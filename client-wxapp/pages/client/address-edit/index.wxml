<view class="container">

  <view class="section">
    <view class="form-item">
      <text class="label">联系人</text>
      <input class="input" placeholder="姓名" value="{{contactName}}" data-field="contactName" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" placeholder="手机号" value="{{contactPhone}}" data-field="contactPhone" bindinput="onInput"/>
    </view>
  </view>

  <view class="section">
    <view class="location-row" bindtap="chooseLocation">
      <text class="location-label">📍 从地图选择位置</text>
      <text class="location-hint">自动填入地址</text>
    </view>
  </view>

  <view class="section">
    <view class="form-item">
      <text class="label">省份</text>
      <input class="input" placeholder="例：广东省" value="{{province}}" data-field="province" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">城市</text>
      <input class="input" placeholder="例：深圳市" value="{{city}}" data-field="city" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">区/县</text>
      <input class="input" placeholder="例：南山区" value="{{district}}" data-field="district" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">详细地址 *</text>
      <input class="input" placeholder="街道、小区、楼栋" value="{{detailAddress}}" data-field="detailAddress" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">门牌号</text>
      <input class="input" placeholder="例：A栋1203（选填）" value="{{doorInfo}}" data-field="doorInfo" bindinput="onInput"/>
    </view>
  </view>

  <view class="section default-row">
    <text class="label">设为默认地址</text>
    <switch checked="{{isDefault}}" bindchange="onDefaultChange" color="#ff6b9d"/>
  </view>

  <view class="footer">
    <button class="btn-save" bindtap="handleSubmit" disabled="{{submitting}}">
      {{submitting ? '保存中...' : (isEdit ? '保存修改' : '保存地址')}}
    </button>
  </view>

</view>
