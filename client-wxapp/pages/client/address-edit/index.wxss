.container {
  min-height: 100vh;
  background-color: #ffffff;
  padding: 40rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}

.input {
  height: 96rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background-color: #ff6b9d;
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}