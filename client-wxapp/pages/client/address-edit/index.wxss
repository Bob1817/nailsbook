.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.section {
  background: #fff;
  margin-bottom: 16rpx;
  padding: 0 32rpx;
}

.form-item {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.form-item:last-child { border-bottom: none; }

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.input {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  color: #333;
}

.location-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
}
.location-label {
  font-size: 28rpx;
  color: #333;
}
.location-hint {
  font-size: 26rpx;
  color: #ff6b9d;
}

.default-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 0 32rpx;
}

.footer {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
}
.btn-save {
  width: 100%;
  height: 96rpx;
  background: #ff6b9d;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-save[disabled] { background: #ccc; }
