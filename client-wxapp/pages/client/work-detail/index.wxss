.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.image-swiper {
  height: 750rpx;
}

.work-image {
  width: 100%;
  height: 100%;
}

.content {
  background-color: #ffffff;
  margin-top: -24rpx;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  position: relative;
}

.tech-section {
  display: flex;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.tech-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.tech-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.tech-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.tech-city {
  font-size: 24rpx;
  color: #999999;
}

.btn-follow {
  background-color: #ff6b9d;
  color: #ffffff;
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  margin: 0;
}

.title-section {
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  background-color: #fff0f5;
  color: #ff6b9d;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.desc-section {
  margin-bottom: 24rpx;
}

.desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.stats-section {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
}

.icon {
  font-size: 40rpx;
  color: #cccccc;
  margin-right: 8rpx;
}

.icon.active {
  color: #ff6b9d;
}

.count {
  font-size: 28rpx;
  color: #666666;
}

.comments-section {
  padding-top: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
}

.comment-item {
  display: flex;
  margin-bottom: 24rpx;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.comment-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.comment-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.comment-time {
  font-size: 22rpx;
  color: #999999;
}
