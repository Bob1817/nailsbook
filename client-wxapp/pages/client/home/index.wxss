.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #ff6b9d 0%, #ff8fab 100%);
  padding: 60rpx 32rpx 120rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
}

.info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.settings image {
  width: 48rpx;
  height: 48rpx;
}

.technician-card {
  background-color: #ffffff;
  margin: -80rpx 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.tech-info {
  display: flex;
  align-items: center;
}

.tech-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.tech-detail {
  display: flex;
  flex-direction: column;
}

.tech-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.tech-status {
  font-size: 24rpx;
  color: #ff6b9d;
}

.btn-chat {
  background-color: #fff0f5;
  color: #ff6b9d;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.quick-actions {
  background-color: #ffffff;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-item image {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
}

.action-item text {
  font-size: 24rpx;
  color: #666666;
}

.section {
  background-color: #ffffff;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.more {
  font-size: 26rpx;
  color: #ff6b9d;
}

.works-scroll {
  white-space: nowrap;
  height: 260rpx;
}

.work-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 24rpx;
}

.work-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.work-title {
  font-size: 24rpx;
  color: #666666;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-list {
  display: flex;
  flex-direction: column;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-item:last-child {
  border-bottom: none;
}

.order-info {
  display: flex;
  flex-direction: column;
}

.order-title {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.status-pending_quote {
  background-color: #fff4e6;
  color: #ff9500;
}

.status-confirmed {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status-completed {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-cancelled {
  background-color: #f5f5f5;
  color: #999999;
}

.empty {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
}

.btn-outline-sm {
  background-color: transparent;
  border: 2rpx solid #ff6b9d;
  color: #ff6b9d;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  margin-top: 20rpx;
}
