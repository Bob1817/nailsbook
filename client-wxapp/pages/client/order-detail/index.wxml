<view class="container" wx:if="{{!loading && order}}">

  <!-- 状态头 -->
  <view class="status-bar status-{{order.status}}">
    <text class="status-text">{{order.statusText}}</text>
    <text class="order-no">{{order.orderNo}}</text>
  </view>

  <!-- 报价卡片（quoted 状态才显示） -->
  <view class="quote-card" wx:if="{{order.status === 'quoted'}}">
    <text class="quote-label">美甲师报价</text>
    <text class="quote-price">¥{{order.price}}</text>
    <view class="quote-meta">
      <text>{{order.serviceDate}} {{order.startTime}}</text>
      <text wx:if="{{order.durationMinutes}}"> · {{order.durationMinutes}}分钟</text>
    </view>
    <text class="quote-remark" wx:if="{{order.techRemark}}">备注：{{order.techRemark}}</text>
    <view class="quote-actions">
      <button class="btn btn-outline" bindtap="rejectQuote">拒绝</button>
      <button class="btn btn-primary" bindtap="acceptQuote">接受报价</button>
    </view>
  </view>

  <!-- 服务信息 -->
  <view class="section">
    <text class="section-title">服务信息</text>
    <view class="info-row">
      <text class="label">服务方式</text>
      <text class="value">{{order.serviceType}}</text>
    </view>
    <view class="info-row" wx:if="{{order.serviceDate}}">
      <text class="label">预约时间</text>
      <text class="value">{{order.serviceDate}} {{order.startTime}}</text>
    </view>
    <view class="info-row" wx:if="{{order.addressText}}">
      <text class="label">上门地址</text>
      <text class="value">{{order.addressText}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="label">备注</text>
      <text class="value">{{order.remark}}</text>
    </view>
  </view>

  <!-- 美甲师信息 -->
  <view class="section" wx:if="{{order.techName}}">
    <text class="section-title">美甲师</text>
    <view class="tech-row">
      <image class="tech-avatar" src="{{order.techAvatar || '/static/logo.svg'}}" mode="aspectFill"/>
      <text class="tech-name">{{order.techName}}</text>
    </view>
  </view>

  <!-- 金额（confirmed/completed 显示） -->
  <view class="section" wx:if="{{order.price && order.status !== 'quoted'}}">
    <text class="section-title">费用</text>
    <view class="info-row">
      <text class="label">服务金额</text>
      <text class="value price">¥{{order.price}}</text>
    </view>
  </view>

  <!-- 取消按钮 -->
  <view class="cancel-wrap"
    wx:if="{{order.status === 'pending_quote' || order.status === 'confirmed'}}">
    <button class="btn-cancel" bindtap="cancelOrder">取消预约</button>
  </view>

</view>

<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>
