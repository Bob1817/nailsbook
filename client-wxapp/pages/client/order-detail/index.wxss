.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

/* 状态头 */
.status-bar {
  padding: 40rpx 32rpx;
  background: #ff6b9d;
}
.status-bar.status-completed { background: #52c41a; }
.status-bar.status-cancelled,
.status-bar.status-rejected  { background: #999; }
.status-bar.status-confirmed  { background: #1890ff; }
.status-bar.status-quoted     { background: #fa8c16; }

.status-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}
.order-no {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
}

/* 报价卡片 */
.quote-card {
  background: #fff;
  margin: 16rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  border: 2rpx solid #fa8c16;
}
.quote-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}
.quote-price {
  font-size: 56rpx;
  font-weight: 700;
  color: #ff6b9d;
  display: block;
  margin-bottom: 12rpx;
}
.quote-meta {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.quote-remark {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 24rpx;
}
.quote-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

/* 区块 */
.section {
  background: #fff;
  margin: 16rpx 0;
  padding: 32rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}
.info-row {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-row:last-child { border-bottom: none; }
.label {
  width: 140rpx;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}
.value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.value.price {
  color: #ff6b9d;
  font-size: 36rpx;
  font-weight: 600;
}

/* 美甲师 */
.tech-row {
  display: flex;
  align-items: center;
}
.tech-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: #f0f0f0;
  margin-right: 20rpx;
}
.tech-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 按钮 */
.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.btn-primary { background: #ff6b9d; color: #fff; }
.btn-outline  { background: #fff; color: #666; border: 2rpx solid #ddd; }

.cancel-wrap {
  padding: 32rpx;
}
.btn-cancel {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #999;
  background: #fff;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  font-size: 28rpx;
  color: #999;
}
