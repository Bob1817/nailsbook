.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}
.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}
.empty-sub {
  font-size: 26rpx;
  color: #999;
}

.list { padding: 16rpx 0; }

.addr-item {
  background: #fff;
  margin-bottom: 16rpx;
  padding: 32rpx;
}
.addr-body { margin-bottom: 20rpx; }
.addr-top {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.addr-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 20rpx;
}
.addr-phone {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}
.tag-default {
  font-size: 22rpx;
  color: #ff6b9d;
  border: 2rpx solid #ff6b9d;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
}
.addr-detail {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.addr-actions {
  display: flex;
  gap: 32rpx;
  border-top: 1rpx solid #f5f5f5;
  padding-top: 20rpx;
}
.action-btn {
  font-size: 26rpx;
  color: #666;
}
.action-btn.danger { color: #ff4d4f; }

.footer {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
}
.btn-add {
  width: 100%;
  height: 96rpx;
  background: #ff6b9d;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
