.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 32rpx 100rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
}

.info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.status-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.active {
  background-color: rgba(82, 196, 26, 0.2);
  color: #52c41a;
}

.status-badge.inactive {
  background-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.settings image {
  width: 48rpx;
  height: 48rpx;
}

.stats-card {
  background-color: #ffffff;
  margin: -60rpx 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #f0f0f0;
}

.quick-actions {
  background-color: #ffffff;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
}

.action-icon image {
  width: 64rpx;
  height: 64rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #ff4d4f;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.action-item text {
  font-size: 24rpx;
  color: #666666;
}

.section {
  background-color: #ffffff;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.more {
  font-size: 26rpx;
  color: #667eea;
}

.schedule-list {
  display: flex;
  flex-direction: column;
}

.schedule-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.schedule-item:last-child {
  border-bottom: none;
}

.time-block {
  width: 120rpx;
  margin-right: 24rpx;
}

.time {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.duration {
  font-size: 22rpx;
  color: #999999;
  display: block;
}

.schedule-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.customer-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.service-type {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.address {
  font-size: 22rpx;
  color: #999999;
}

.schedule-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.status-confirmed {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status-pending {
  background-color: #fff4e6;
  color: #ff9500;
}

.empty {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
}
