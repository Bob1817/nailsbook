.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.search-bar {
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input {
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.customer-list {
  padding: 24rpx 32rpx;
}

.customer-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
}

.customer-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.customer-info {
  flex: 1;
}

.customer-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.customer-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 16rpx;
}

.customer-tags {
  display: flex;
}

.tag {
  background-color: #f0f5ff;
  color: #667eea;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-left: 8rpx;
}

.customer-phone {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 12rpx;
}

.customer-stats {
  display: flex;
}

.stat {
  font-size: 22rpx;
  color: #666666;
  margin-right: 24rpx;
}

.btn-chat {
  background-color: #667eea;
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999999;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}
