<view class="container">

  <view class="header">
    <view class="logo-circle">N</view>
    <text class="title">美甲师登录</text>
  </view>

  <view wx:if="{{step === 'phone'}}" class="form">
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" placeholder="请输入手机号"
        value="{{phone}}" data-field="phone" bindinput="onInput"/>
    </view>
    <button class="btn-primary" bindtap="handlePhoneNext">下一步</button>
  </view>

  <view wx:elif="{{step === 'login'}}" class="form">
    <view class="form-item">
      <text class="label">手机号</text>
      <view class="readonly">{{phone}}</view>
    </view>
    <view class="form-item">
      <text class="label">密码</text>
      <input class="input" type="text" password placeholder="请输入密码"
        value="{{password}}" data-field="password" bindinput="onInput"/>
    </view>
    <button class="btn-primary" bindtap="handleLogin" disabled="{{loading}}">
      {{loading ? '登录中...' : '登录'}}
    </button>
    <text class="link" data-step="phone" bindtap="switchPhase">换个手机号</text>
  </view>

  <view wx:else class="form">
    <view class="hint-banner">该手机号未注册，请使用邀请密钥完成注册</view>
    <view class="form-item">
      <text class="label">手机号</text>
      <view class="readonly">{{phone}}</view>
    </view>
    <view class="form-item">
      <text class="label">邀请密钥</text>
      <input class="input upper" placeholder="16 位大写字母+数字"
        maxlength="16" value="{{inviteKey}}" data-field="inviteKey" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">姓名</text>
      <input class="input" placeholder="请输入您的姓名"
        value="{{name}}" data-field="name" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">设置密码</text>
      <input class="input" type="text" password placeholder="至少 8 位，含字母和数字"
        value="{{password}}" data-field="password" bindinput="onInput"/>
    </view>
    <view class="form-item">
      <text class="label">确认密码</text>
      <input class="input" type="text" password placeholder="再次输入密码"
        value="{{confirmPassword}}" data-field="confirmPassword" bindinput="onInput"/>
    </view>
    <button class="btn-primary" bindtap="handleRegister" disabled="{{loading}}">
      {{loading ? '注册中...' : '注册并登录'}}
    </button>
    <text class="link" data-step="phone" bindtap="switchPhase">换个手机号</text>
  </view>

  <view class="footer">
    <navigator url="/pages/role-select/index" class="back-link">返回选择身份</navigator>
  </view>
</view>
