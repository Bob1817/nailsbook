<view class="container">
  <view class="header">
    <text class="title">美甲师登录</text>
    <text class="subtitle">管理您的预约和工作</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">手机号</text>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="请输入注册手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-item">
      <text class="label">验证码</text>
      <view class="code-input">
        <input
          class="input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <button
          class="btn-code"
          bindtap="sendCode"
        >
          {{countText}}
        </button>
      </view>
    </view>

    <button class="btn-primary" bindtap="handleSubmit">
      登录
    </button>
  </view>

  <view class="footer">
    <navigator url="/pages/role-select/index" class="back-link">
      返回选择身份
    </navigator>
  </view>
</view>