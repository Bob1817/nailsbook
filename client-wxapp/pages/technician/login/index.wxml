<view class="container">
  <view class="header">
    <text class="title">美甲师登录</text>
    <text class="subtitle">管理您的预约和工作</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">手机号</text>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="请输入注册手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-item">
      <text class="label">密码</text>
      <input
        class="input"
        password
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <button class="btn-primary" bindtap="handleSubmit" disabled="{{loading}}">
      登录
    </button>
  </view>

  <view class="footer">
    <navigator url="/pages/role-select/index" class="back-link">
      返回选择身份
    </navigator>
  </view>
</view>
