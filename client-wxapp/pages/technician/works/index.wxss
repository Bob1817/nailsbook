.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 16rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}
.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}
.empty-sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
}
.btn-add-first {
  height: 88rpx;
  padding: 0 64rpx;
  background: #ff6b9d;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.work-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.work-cover {
  width: 100%;
  height: 300rpx;
  display: block;
}

.hidden-mask {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 300rpx;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}
.hidden-label {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.work-info {
  padding: 16rpx 20rpx;
}
.work-title {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.work-actions {
  display: flex;
  gap: 20rpx;
}
.action-btn {
  font-size: 24rpx;
  color: #ff6b9d;
}
.action-btn.danger { color: #ff4d4f; }

.add-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
  background: #fafafa;
  border: 2rpx dashed #ddd;
}
.add-icon {
  font-size: 72rpx;
  color: #ccc;
  line-height: 1;
  margin-bottom: 12rpx;
}
.add-text {
  font-size: 26rpx;
  color: #999;
}
