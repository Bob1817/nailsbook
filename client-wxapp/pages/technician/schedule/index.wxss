.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.week-strip {
  display: flex;
  background: #fff;
  padding: 16rpx 0 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.day-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-radius: 12rpx;
  margin: 0 4rpx;
}
.day-cell.selected {
  background: #ff6b9d;
}
.day-dow {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.day-cell.selected .day-dow { color: rgba(255,255,255,0.8); }
.day-num {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.day-cell.selected .day-num { color: #fff; }

.date-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}
.date-text { font-size: 28rpx; font-weight: 600; color: #333; }
.count-text { font-size: 24rpx; color: #999; }

.empty {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-text { font-size: 30rpx; color: #999; }

.order-list { padding: 0 16rpx; }

.order-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 28rpx 24rpx;
  align-items: center;
}

.order-time-col {
  width: 100rpx;
  flex-shrink: 0;
  text-align: center;
}
.order-time {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff6b9d;
}

.order-body {
  flex: 1;
  margin-left: 24rpx;
}
.order-client {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}
.order-services {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}
.order-status {
  font-size: 22rpx;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  background: #f5f5f5;
  color: #999;
}
.order-status.confirmed { background: #e6f7ff; color: #1890ff; }
.order-status.quoted { background: #fff7e6; color: #fa8c16; }
.order-status.completed { background: #f6ffed; color: #52c41a; }
