.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.filter-tabs {
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  overflow-x: auto;
  white-space: nowrap;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.tab {
  font-size: 28rpx;
  color: #666666;
  margin-right: 40rpx;
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}

.tab.active {
  color: #667eea;
  font-weight: 600;
  border-bottom: 4rpx solid #667eea;
}

.order-list {
  padding: 100rpx 32rpx 32rpx;
}

.order-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.status-pending_quote {
  background-color: #fff4e6;
  color: #ff9500;
}

.status-quoted {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status-confirmed {
  background-color: #d9f7be;
  color: #52c41a;
}

.status-completed {
  background-color: #f5f5f5;
  color: #666666;
}

.order-body {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.customer-info {
  display: flex;
  align-items: center;
  margin-right: 24rpx;
}

.customer-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.customer-detail {
  display: flex;
  flex-direction: column;
}

.customer-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.customer-phone {
  font-size: 22rpx;
  color: #999999;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.service-type {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 4rpx;
}

.service-time {
  font-size: 24rpx;
  color: #999999;
}

.price-info {
  text-align: right;
}

.price {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
}

.order-footer {
  display: flex;
  justify-content: flex-end;
}

.btn-quote {
  background-color: #667eea;
  color: #ffffff;
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  border-radius: 32rpx;
  margin: 0;
  border: none;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999999;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}
