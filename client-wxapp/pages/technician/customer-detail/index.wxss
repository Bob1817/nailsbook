.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.profile-card {
  background: #fff;
  padding: 32rpx;
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  flex-shrink: 0;
}
.profile-info {
  flex: 1;
  margin-left: 24rpx;
}
.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}
.phone { font-size: 26rpx; color: #999; }

.stats { margin-left: 16rpx; }
.stat-item { text-align: center; }
.stat-num { font-size: 36rpx; font-weight: 600; color: #ff6b9d; display: block; }
.stat-label { font-size: 22rpx; color: #999; }

.section {
  background: #fff;
  margin-bottom: 16rpx;
  padding: 28rpx 32rpx;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-title { font-size: 28rpx; font-weight: 600; color: #333; }
.section-action { font-size: 26rpx; color: #ff6b9d; }

.tag-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag {
  font-size: 24rpx;
  color: #ff6b9d;
  background: #fff0f6;
  border-radius: 8rpx;
  padding: 8rpx 20rpx;
}
.no-tags { font-size: 26rpx; color: #ccc; }

.tag-edit {}
.tag-input {
  width: 100%;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}
.tag-edit-actions { display: flex; gap: 20rpx; }
.btn-cancel {
  flex: 1; height: 80rpx;
  background: #f5f5f5; color: #666;
  border-radius: 40rpx; font-size: 28rpx;
}
.btn-save {
  flex: 1; height: 80rpx;
  background: #ff6b9d; color: #fff;
  border-radius: 40rpx; font-size: 28rpx;
}

.no-orders { padding: 40rpx 0; text-align: center; }
.no-orders-text { font-size: 28rpx; color: #ccc; }

.order-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.order-item:last-child { border-bottom: none; }
.order-left {}
.order-date { font-size: 28rpx; color: #333; display: block; margin-bottom: 6rpx; }
.order-type { font-size: 24rpx; color: #999; }
.order-right { display: flex; align-items: center; gap: 12rpx; }
.order-status {
  font-size: 22rpx;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  background: #f5f5f5;
  color: #999;
}
.order-status.confirmed { background: #e6f7ff; color: #1890ff; }
.order-status.completed { background: #f6ffed; color: #52c41a; }
.order-status.cancelled { color: #ccc; }
.order-arrow { font-size: 36rpx; color: #ccc; }
