.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.message-list {
  padding: 20rpx;
}

.message-item {
  margin-bottom: 32rpx;
}

.message-content {
  background-color: #ffffff;
  padding: 24rpx;
  border-radius: 16rpx;
}

.send-time {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 20rpx;
  display: flex;
}

.input {
  flex: 1;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 32rpx;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background-color: #ff6b9d;
  color: #ffffff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
}