<view class="container">
  <view class="logo-section">
    <view class="logo-circle">N</view>
    <text class="app-name">NailBook</text>
    <text class="app-desc">美甲预约，让美丽更简单</text>
  </view>

  <view class="role-section">
    <text class="section-title">选择您的身份</text>

    <view class="role-card" bindtap="selectRole" data-role="client">
      <view class="role-icon client-icon">客</view>
      <view class="role-info">
        <text class="role-title">我是客户</text>
        <text class="role-desc">浏览作品、预约美甲服务</text>
      </view>
      <text class="arrow">›</text>
    </view>

    <view class="role-card" bindtap="selectRole" data-role="technician">
      <view class="role-icon tech-icon">师</view>
      <view class="role-info">
        <text class="role-title">我是美甲师</text>
        <text class="role-desc">管理预约、服务客户、展示作品</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">登录即表示同意《用户协议》和《隐私政策》</text>
  </view>
</view>