# 数据库连接配置
# 开发: DATABASE_URL="file:./dev.db"
# 生产: DATABASE_URL="postgresql://user:password@host:5432/nailbook" 或 mysql
DATABASE_URL="file:./dev.db"

# JWT 密钥（各角色独立密钥，生产环境务必替换为强随机字符串）
# 生成方法: openssl rand -base64 48
ADMIN_JWT_SECRET=change-me-admin-secret-at-least-32-chars
TECHNICIAN_JWT_SECRET=change-me-technician-secret-at-least-32-chars
CLIENT_JWT_SECRET=change-me-client-secret-at-least-32-chars
JWT_EXPIRES_IN=8h

# 应用端口
PORT=3000

# 环境
NODE_ENV=development

# CORS 白名单，多个域名用英文逗号分隔；生产环境必须显式配置
# 开发: CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
# 生产: CORS_ORIGINS=https://client.yourdomain.com,https://admin.yourdomain.com,https://landing.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# 上传文件基础 URL（开发环境跟随后端，生产环境指向 OSS/CDN）
UPLOAD_BASE_URL=http://localhost:3000

# 生产环境默认关闭 Swagger，如需临时开启请显式设置 true
ENABLE_SWAGGER=false
